# Copy to /opt/reloop/next-app/.env.local  (auto-loaded by `next start`)
# Server-side only — never exposed to the browser.
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
# Next talks to the ML service internally over loopback:
ML_SERVICE_URL=http://localhost:8000
# Optional model overrides:
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
# Triage routes read this for CORS headers (same-origin works without it,
# but set it so cross-origin/preflight responses are correct):
ALLOWED_ORIGINS=https://SERVER_NAME_PLACEHOLDER
# NOTE: the vision-stream WS URL is derived from the page origin at runtime,
# so you do NOT need NEXT_PUBLIC_VISION_WS_URL unless the ML host differs.
